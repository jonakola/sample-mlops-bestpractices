# .env — runtime overrides for src/config/config.py
#
# Copy this file to .env (`cp .env.example .env`) and customize.
# Values here override defaults in src/config/config.yaml.
#
# When the CloudFormation stack creates a SageMaker JupyterLab space, the
# space-launch lifecycle script generates a .env automatically from the
# stack outputs. You only need to copy this file manually if you're running
# the notebooks against your own SageMaker domain (not the CFN one).

# ============================================================================
# AWS context (required)
# ============================================================================
AWS_DEFAULT_REGION=us-west-2

# QuickSight identity region — the region your QuickSight account was first
# activated in. ALL QuickSight API calls must hit this endpoint, regardless
# of where your data lives. Defaults to us-east-1 (the most common). Look it
# up via: QuickSight console → Manage QuickSight → Account settings → top of page.
QUICKSIGHT_IDENTITY_REGION=us-east-1

# SageMaker execution role — used by the training pipeline + the deployed
# endpoint. Get this from the IAM console or the CFN stack output.
SAGEMAKER_EXEC_ROLE=arn:aws:iam::YOUR_ACCOUNT_ID:role/YOUR_SAGEMAKER_ROLE

# Lambda execution role — used by the drift-monitor + monitoring-writer
# Lambdas. CFN's LambdaExecutionRole output gives you this ARN.
LAMBDA_EXEC_ROLE=arn:aws:iam::YOUR_ACCOUNT_ID:role/YOUR_LAMBDA_EXEC_ROLE

# Project name — used as a prefix for resource names (buckets, queues, etc.)
PROJECT_NAME=fraud-detection-monitoring

# ============================================================================
# MLflow tracking
# ============================================================================
# ARN of the SageMaker MLflow tracking server. Get this from the SageMaker
# Studio UI: Partner AI Apps → MLflow → View Details.
MLFLOW_TRACKING_URI=arn:aws:sagemaker:us-west-2:YOUR_ACCOUNT_ID:mlflow-app/app-YOUR_APP_ID

# ============================================================================
# S3 / Athena
# ============================================================================
# S3 bucket for training data, evaluation data, drift baselines, etc.
DATA_S3_BUCKET=fraud-detection-monitoring-data-YOUR_ACCOUNT_ID

# Athena database where all 7 Iceberg tables live (created by CFN).
ATHENA_DATABASE=fraud_detection

# Athena query results location.
ATHENA_OUTPUT_S3=s3://fraud-detection-monitoring-data-YOUR_ACCOUNT_ID/athena-results/

# ============================================================================
# Inference logging (set by notebook 2 at endpoint-deploy time)
# ============================================================================
# Full SQS queue URL the inference handler posts predictions to. Resolved at
# endpoint-deploy time from CFN's InferenceLoggerQueue resource — you don't
# usually need to set this here.
SQS_QUEUE_URL=

# Master switch — when false, the inference handler returns predictions but
# does NOT send to SQS (skips Athena logging entirely).
ENABLE_ATHENA_LOGGING=true

# ============================================================================
# Drift monitoring
# ============================================================================
# 🚨 EMAIL FOR DRIFT ALERTS — replace nobody@example.com with a real address.
# The default is the IANA-reserved non-deliverable domain so the deploy
# succeeds out of the box, but SNS subscriptions to it sit in
# PendingConfirmation forever and no alert email is ever delivered.
# The drift Lambda still runs and writes results to monitoring_responses;
# you just won't be notified when thresholds are breached.
ALERT_EMAIL=nobody@example.com

# Optional: override drift compute lookback windows (defaults are 7 / 30 days).
# MONITORING_DATA_DRIFT_LOOKBACK_DAYS=7
# MONITORING_MODEL_DRIFT_LOOKBACK_DAYS=30
